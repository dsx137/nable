{
  "name": "@dsx137/nable",
  "version": "1.2.5",
  "description": "personal lib",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsx --test test/*.test.ts",
    "test:watch": "tsx --test --watch test/*.test.ts",
    "package:lint": "publint --strict",
    "package:types": "attw --pack . --profile esm-only",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build && npm run package:lint && npm run package:types",
    "prepack": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "typescript",
    "library"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsx137/nable.git"
  },
  "author": "dsx137",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/dsx137/nable/issues"
  },
  "homepage": "https://github.com/dsx137/nable#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@arethetypeswrong/cli": "^0.18.5",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
